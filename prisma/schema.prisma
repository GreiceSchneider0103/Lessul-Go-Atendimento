generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  ATENDENTE
  SUPERVISOR
  ADMIN
}

enum Empresa {
  LESSUL
  MS_DECOR
  VIVA_VIDA
  MOVELBENTO
  MODIFIKA
}

enum StatusReclamacao {
  AFETANDO
  NAO_AFETANDO
  REMOVIDA
}

enum Motivo {
  DESISTENCIA
  DEFEITO_FABRICACAO
  PRODUTO_INCORRETO
  FALTANDO_ITENS
  PRODUTO_DANIFICADO
  PROBLEMA
}

enum Resolucao {
  ASSISTENCIA
  DEVOLUCAO
  REEMBOLSO
  RESOLVIDO
}

enum StatusTicket {
  CONCLUIDO
  ABERTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_DEVOLUCAO
  AGUARDANDO_ASSISTENCIA
  AGUARDANDO_MARKETPLACE
}

enum AcaoAuditoria {
  CREATE
  UPDATE
  SOFT_DELETE
  STATUS_CHANGE
}

model Usuario {
  id           String   @id @default(uuid())
  authUserId   String   @unique
  nome         String
  email        String   @unique
  perfil       Perfil
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  ticketsCriados    Ticket[]          @relation("tickets_criados")
  ticketsAtualizados Ticket[]         @relation("tickets_atualizados")
  auditorias         TicketAuditoria[]
}

model Ticket {
  id                String           @id @default(uuid())
  nomeCliente       String
  dataCompra        DateTime
  numeroVenda       String
  linkPedido        String?
  uf                String           @db.Char(2)
  cpf               String
  canalMarketplace  String
  empresa           Empresa
  produto           String
  sku               String
  fabricante        String?
  transportadora    String?
  statusReclamacao  StatusReclamacao
  dataReclamacao    DateTime
  motivo            Motivo
  detalhesCliente   String?
  resolucao         Resolucao?
  valorReembolso    Decimal          @db.Decimal(12, 2) @default(0)
  valorColeta       Decimal          @db.Decimal(12, 2) @default(0)
  custosTotais      Decimal          @db.Decimal(12, 2) @default(0)
  statusTicket      StatusTicket     @default(ABERTO)
  responsavelId     String?
  criadoEm          DateTime         @default(now())
  criadoPorId       String
  atualizadoPorId   String
  atualizadoEm      DateTime         @updatedAt
  prazoConclusao    DateTime?
  ativo             Boolean          @default(true)

  criadoPor         Usuario          @relation("tickets_criados", fields: [criadoPorId], references: [id])
  atualizadoPor     Usuario          @relation("tickets_atualizados", fields: [atualizadoPorId], references: [id])
  auditoria         TicketAuditoria[]

  @@index([canalMarketplace, empresa])
  @@index([statusTicket, statusReclamacao])
  @@index([dataReclamacao])
  @@index([responsavelId])
}

model TicketAuditoria {
  id          String         @id @default(uuid())
  ticketId    String
  acao        AcaoAuditoria
  campo       String
  valorAntigo String?
  valorNovo   String?
  usuarioId   String
  dataHora    DateTime       @default(now())

  ticket      Ticket         @relation(fields: [ticketId], references: [id])
  usuario     Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([ticketId, dataHora])
  @@index([usuarioId])
}
