generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id                 String            @id @default(uuid())
  authUserId         String            @unique
  nome               String
  email              String            @unique
  perfil             Perfil
  ativo              Boolean           @default(true)
  criadoEm           DateTime          @default(now())
  atualizadoEm       DateTime          @updatedAt
  ticketsAtualizados Ticket[]          @relation("tickets_atualizados")
  ticketsCriados     Ticket[]          @relation("tickets_criados")
  ticketsResponsavel Ticket[]          @relation("tickets_responsavel")
  auditorias         TicketAuditoria[]
}

model Ticket {
  id               String            @id @default(uuid())
  nomeCliente      String
  dataCompra       DateTime
  numeroVenda      String
  linkPedido       String?
  uf               String            @db.Char(2)
  cpf              String
  canalMarketplace String
  empresa          Empresa
  produto          String
  sku              String
  fabricante       String?
  transportadora   String?
  statusReclamacao StatusReclamacao
  dataReclamacao   DateTime
  motivo           Motivo
  detalhesCliente  String?
  resolucao        Resolucao?
  valorReembolso   Decimal           @default(0) @db.Decimal(12, 2)
  valorColeta      Decimal           @default(0) @db.Decimal(12, 2)
  custosTotais     Decimal           @default(0) @db.Decimal(12, 2)
  statusTicket     StatusTicket      @default(ABERTO)
  responsavelId    String?
  criadoEm         DateTime          @default(now())
  criadoPorId      String
  atualizadoPorId  String
  atualizadoEm     DateTime          @updatedAt
  prazoConclusao   DateTime?
  ativo            Boolean           @default(true)
  mesReclamacao    Int
  anoReclamacao    Int
  slaStatus        String            @default("NO_PRAZO")
  atualizadoPor    Usuario           @relation("tickets_atualizados", fields: [atualizadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  criadoPor        Usuario           @relation("tickets_criados", fields: [criadoPorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsavel      Usuario?          @relation("tickets_responsavel", fields: [responsavelId], references: [id])
  auditoria        TicketAuditoria[]

  @@index([dataReclamacao])
  @@index([canalMarketplace, empresa], map: "Ticket_marketplace_empresa_idx")
  @@index([mesReclamacao, anoReclamacao], map: "Ticket_mes_ano_idx")
  @@index([responsavelId], map: "Ticket_responsavel_idx")
  @@index([statusTicket, statusReclamacao], map: "Ticket_status_idx")
}

model TicketAuditoria {
  id          String        @id @default(uuid())
  ticketId    String
  acao        AcaoAuditoria
  campo       String
  valorAntigo String?
  valorNovo   String?
  usuarioId   String
  dataHora    DateTime      @default(now())
  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario     Usuario       @relation(fields: [usuarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ticketId, dataHora], map: "TicketAuditoria_ticket_data_idx")
  @@index([usuarioId], map: "TicketAuditoria_usuario_idx")
}

enum Perfil {
  ATENDENTE
  SUPERVISOR
  ADMIN
}

enum Empresa {
  LESSUL
  MS_DECOR
  VIVA_VIDA
  MOVELBENTO
  MODIFIKA
}

enum StatusReclamacao {
  AFETANDO
  NAO_AFETANDO
  REMOVIDA
}

enum Motivo {
  DESISTENCIA
  DEFEITO_FABRICACAO
  PRODUTO_INCORRETO
  FALTANDO_ITENS
  PRODUTO_DANIFICADO
  PROBLEMA
}

enum Resolucao {
  ASSISTENCIA
  DEVOLUCAO
  REEMBOLSO
  RESOLVIDO
}

enum StatusTicket {
  CONCLUIDO
  ABERTO
  AGUARDANDO_CLIENTE
  AGUARDANDO_DEVOLUCAO
  AGUARDANDO_ASSISTENCIA
  AGUARDANDO_MARKETPLACE
}

enum AcaoAuditoria {
  CREATE
  UPDATE
  SOFT_DELETE
  STATUS_CHANGE
}
